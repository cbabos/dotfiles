music_directory        "/home/cbabos/Music"
playlist_directory     "/home/cbabos/.mpd/playlists"
db_file            "/home/cbabos/.mpd/tag_cache"
log_file        "/home/cbabos/.mpd/mpd.log"
pid_file        "/home/cbabos/.mpd/mpd.pid"
state_file        "/home/cbabos/.mpd/mpdstate"

### PULSE AUDIO ######################################
audio_output {
    type    "pulse"
    name    "MPD"                                                                 
}

